# ─────────────────────────────────────────────
# CI Agent — environment variable reference
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── AI Provider ──────────────────────────────
# "anthropic" or "openai" (default: anthropic)
CI_AGENT_PROVIDER=anthropic

# ── Anthropic (Claude) ───────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── OpenAI (or any compatible endpoint) ──────
# OPENAI_API_KEY=your-openai-api-key
# CI_AGENT_BASE_URL=https://api.openai.com/v1    # omit to use OpenAI default

# ── Model ────────────────────────────────────
# CI_AGENT_MODEL=claude-sonnet-4-20250514        # anthropic default
# CI_AGENT_MODEL=gpt-4o                          # openai example

# ── GitHub ───────────────────────────────────
# Required for fetching workflow runs, logs, and action SHAs
GITHUB_TOKEN=your-github-token

# ── Output ───────────────────────────────────
# Report language: en (English) or zh (Chinese)
# CI_AGENT_LANGUAGE=en

# ── API Authentication ───────────────────────
# Static Bearer token for protecting API endpoints.
# When unset, auth is skipped (local dev mode).
# CI_AGENT_API_KEY=

# ── Server ───────────────────────────────────
# Allowed origins for the backend CORS policy (comma-separated)
# CORS_ORIGINS=http://localhost:3000

# Log level for the ci_optimizer namespace
# CI_AGENT_LOG_LEVEL=INFO

# ── Webhooks ──────────────────────────────────
# HMAC secret shared with GitHub webhook configuration.
# When unset, signature verification is skipped.
# WEBHOOK_SECRET=

# ── Langfuse (LLM Observability) ─────────────
# When both keys are set, all LLM calls are traced to Langfuse.
# When unset, tracing is silently disabled.
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Caching ──────────────────────────────────
# Reuse completed reports for the same repo+filters within this window.
# Set to 0 to disable caching entirely.
# CI_AGENT_CACHE_TTL_HOURS=24

# ── Failure Triage (per-run AI diagnosis, issue #35) ─────
# Model used for the default "Diagnose" action (fast + cheap).
# DIAGNOSE_DEFAULT_MODEL=claude-haiku-4-5-20251001
# Model used when the user clicks "Deep Analysis" (slower, more accurate).
# DIAGNOSE_DEEP_MODEL=claude-sonnet-4-20250514
# Auto-run diagnosis when a webhook reports a failed workflow_run.
# DIAGNOSE_AUTO_ON_WEBHOOK=true
# Fraction of failing runs to auto-diagnose (0.0–1.0). Set lower on busy repos.
# DIAGNOSE_SAMPLE_RATE=1.0
# Daily USD ceiling for auto-diagnosis. Manual diagnose calls always proceed.
# DIAGNOSE_BUDGET_USD_DAY=1.0
# Dedup window for identical error signatures (hours).
# DIAGNOSE_SIGNATURE_TTL_HOURS=24