# AI Provider: "anthropic" or "openai" (default: anthropic)
# CI_AGENT_PROVIDER=anthropic

# --- Anthropic Provider ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- OpenAI Provider ---
# OPENAI_API_KEY=your-openai-api-key
# CI_AGENT_BASE_URL=https://api.openai.com/v1    # or custom endpoint

# GitHub Token for fetching CI run history and logs (recommended)
GITHUB_TOKEN=your-github-token

# Model (optional, default depends on provider)
# CI_AGENT_MODEL=claude-sonnet-4-20250514        # for anthropic
# CI_AGENT_MODEL=gpt-5.4                         # for openai

# Report language: en (English) or zh (Chinese), default: en
# CI_AGENT_LANGUAGE=zh
