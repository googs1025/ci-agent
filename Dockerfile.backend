FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

# Non-root user
RUN groupadd --gid 1001 ciagent && \
    useradd --uid 1001 --gid ciagent --shell /bin/bash --no-create-home ciagent

WORKDIR /app

# Step 1: install declared dependencies (cached unless pyproject.toml changes)
COPY pyproject.toml ./
RUN python -c "import tomllib,pathlib; d=tomllib.load(open('pyproject.toml','rb')); pathlib.Path('/tmp/deps.txt').write_text('\n'.join(d['project']['dependencies']))" \
    && pip install --no-cache-dir -r /tmp/deps.txt

# Step 2: copy source + skills, then register the package (no extra deps)
COPY src/ ./src/
COPY skills/ ./skills/
RUN pip install --no-cache-dir --no-deps -e .

# Persistent data dir
RUN mkdir -p /data/.ci-agent && chown -R ciagent:ciagent /data /app

USER ciagent

ENV PYTHONUNBUFFERED=1
ENV HOME=/data

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

CMD ["uvicorn", "ci_optimizer.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
